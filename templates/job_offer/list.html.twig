{% extends 'base.html.twig' %} {% block title %}Tout vos offres d'emplois{%
endblock %} {% block body %}
<div class="container px-4 py-16 mx-auto">
  <!-- Section des offres d'emploi -->
  <h2 class="mt-16 mb-8 text-4xl font-bold text-gray-800">Tout vos offres d'emplois</h2>
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
    {% for job_offer in job_offers %}
    <div
      class="overflow-hidden transition duration-300 transform bg-white rounded-lg shadow-md hover:scale-105"
    >
      <div class="p-6">
        <h3 class="text-lg font-semibold text-gray-800">
          {{ job_offer.title }}
        </h3>
        <p class="text-gray-600">{{ job_offer.company }}</p>
        <p class="mt-2 text-sm text-gray-500">
          <i class="fas fa-map-marker-alt"></i> {{ job_offer.location }}
        </p>
        <p class="mt-1 text-sm text-gray-500">
          <i class="fas fa-money-bill-wave"></i> {{ job_offer.salary }}
        </p>
        <a
          href="{{ path('app_job_offer_show', { id: job_offer.id }) }}"
          class="inline-block mt-4 text-orange-400 hover:underline"
        >
          Voir les détails
        </a>
      </div>
    </div>
    {% else %}
    <p class="col-span-4 text-center text-gray-500">
      Aucune offre d'emploi disponible pour le moment.
    </p>
    {% endfor %}
  </div>

  <div class="mt-8 text-right">
    <a
      href="{{ path('app_job_offer_new') }}"
      class="px-4 py-2 text-white bg-orange-400 rounded-md hover:bg-orange-500"
    >
      Ajouter une offre
    </a>
  </div>
</div>

{% endblock %}
